{
  "info": {
    "name": "Microservices Inventory Management System API",
    "description": "Postman collection for the LogicVeda Microservices Inventory Management System project.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"admin\",\"password\":\"ChangeMe123!\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Products - Create Indian Warehouse Product",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/products",
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Handheld Barcode Scanner\",\"description\":\"USB-C scanner for Indian warehouse dispatch counters.\",\"category\":\"Warehouse Equipment\",\"price\":2499,\"stockLevel\":25,\"reorderThreshold\":5}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('productId', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Products - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/products?limit=20"
      }
    },
    {
      "name": "Orders - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/orders",
        "body": {
          "mode": "raw",
          "raw": "{\"customerName\":\"Aarav Retail LLP\",\"customerEmail\":\"ops@aaravretail.in\",\"customerAddress\":\"Indiranagar, Bengaluru, Karnataka 560038\",\"items\":[{\"productId\":\"{{productId}}\",\"quantity\":1}]}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('orderId', json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Orders - Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/orders/{{orderId}}"
      }
    },
    {
      "name": "Reports - Sales",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/reports/sales"
      }
    },
    {
      "name": "Gateway - Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Gateway - Prometheus Metrics",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/metrics/prometheus"
      }
    }
  ]
}
