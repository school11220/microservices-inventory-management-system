NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
INTERNAL_EVENT_TOKEN=replace-with-an-internal-event-token
CORS_ORIGIN=http://localhost:5173

AUTH_DATABASE_URL=postgresql://inventory:inventory@localhost:5432/auth_db?schema=public
AUTH_DIRECT_URL=postgresql://inventory:inventory@localhost:5432/auth_db?schema=public
INVENTORY_DATABASE_URL=postgresql://inventory:inventory@localhost:5432/inventory_db?schema=public
INVENTORY_DIRECT_URL=postgresql://inventory:inventory@localhost:5432/inventory_db?schema=public
ORDER_DATABASE_URL=postgresql://inventory:inventory@localhost:5432/order_db?schema=public
ORDER_DIRECT_URL=postgresql://inventory:inventory@localhost:5432/order_db?schema=public
REPORTING_DATABASE_URL=postgresql://inventory:inventory@localhost:5432/reporting_db?schema=public
REPORTING_DIRECT_URL=postgresql://inventory:inventory@localhost:5432/reporting_db?schema=public
EVENT_STORE_DATABASE_URL=postgresql://inventory:inventory@localhost:5432/event_bus_db?schema=public

REDIS_URL=redis://localhost:6379
EVENT_TRANSPORT=http
KAFKA_BROKERS=
KAFKA_EVENTS_TOPIC=inventory.domain-events
SEARCH_BACKEND=postgres
OPENSEARCH_URL=http://localhost:9200
PRODUCT_SEARCH_INDEX=inventory-products
PAYMENT_SIMULATION_MODE=success
ALLOW_PUBLIC_ADMIN_REGISTRATION=false

AUTH_SERVICE_URL=http://localhost:3001
INVENTORY_SERVICE_URL=http://localhost:3002
ORDER_SERVICE_URL=http://localhost:3003
REPORTING_SERVICE_URL=http://localhost:3004
EVENT_BUS_URL=http://localhost:3005
GATEWAY_PORT=3000
GATEWAY_RATE_LIMIT_PER_MINUTE=1000
GATEWAY_UPSTREAM_TIMEOUT_MS=8000
GATEWAY_CIRCUIT_FAILURE_THRESHOLD=5
GATEWAY_CIRCUIT_RESET_MS=30000
GATEWAY_BULKHEAD_LIMIT=100
VITE_API_URL=http://localhost:3000
